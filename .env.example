# Database
DATABASE_URL="postgresql://nametag:nametag_dev_password@localhost:5432/nametag_db?schema=public"

# NextAuth (configure in Stage 3)
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-secret-key-here

# Resend (Email)
RESEND_API_KEY=your-resend-api-key
